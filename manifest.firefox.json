{
  "manifest_version": 3,
  "name": "MakerWorld to Snapmaker U1",
  "version": "1.2.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "makerworld-to-snapmaker-u1@dragon2203",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "description": "Convert MakerWorld print profiles into Snapmaker U1 project files directly in your browser.",
  "permissions": ["downloads", "storage"],
  "host_permissions": ["https://makerworld.com/*"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://makerworld.com/*"],
      "js": [
        "lib/jszip.min.js",

        "u1_custom_printer_profiles.js",
        "u1_filament_merge.js",
        "u1_project_merge.js",
        "u1_profile_resolver.js",
        "u1_compatibility.js",
        "u1_model_parser.js",
        "u1_bambu_parser.js",
        "u1_project_parser.js",
        "u1_project_builder.js",
        "u1_3mf_metadata.js",
        "u1_project_report.js",
        "converter.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "assets/profiles/*", "injected.js"],
      "matches": ["https://makerworld.com/*"]
    }
  ]
}